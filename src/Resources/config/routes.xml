<?xml version="1.0" encoding="UTF-8" ?>
<routes xmlns="http://symfony.com/schema/routing"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://symfony.com/schema/routing
        https://symfony.com/schema/routing/routing-1.0.xsd">

    <!-- Storefront routes for the embedded Loyalty Shop widget -->
    <route id="frontend.loyaltyshop.cart.add" path="/loyaltyshop/cart/add" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Storefront\LoyaltyShopController::addToCart</default>
        <default key="_routeScope">
            <list>
                <string>storefront</string>
            </list>
        </default>
        <default key="XmlHttpRequest">true</default>
        <default key="csrf_protected">false</default>
    </route>

    <route id="frontend.loyaltyshop.discount.claim" path="/loyaltyshop/discount/claim" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Storefront\LoyaltyShopController::claimDiscount</default>
        <default key="_routeScope">
            <list>
                <string>storefront</string>
            </list>
        </default>
        <default key="XmlHttpRequest">true</default>
        <default key="csrf_protected">false</default>
    </route>

    <!-- Store API routes for frontend (customer session auth) -->
    <route id="store-api.loyalty.cart.add" path="/store-api/loyalty/cart/add" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::addProductApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>
    
    <route id="store-api.loyalty.cart.remove" path="/store-api/loyalty/cart/remove" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::removeProductApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>
    
    <route id="store-api.loyalty.cart.remove.all" path="/store-api/loyalty/cart" methods="DELETE">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::removeAllProductsApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>
    
    <route id="store-api.loyalty.cart.claim.discount" path="/store-api/loyalty/cart/claim-discount" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::claimDiscountApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>

    <!-- Product Feed (NDJSON for LoyaltyEngage / Channable) -->
    <route id="api.action.loyalty.feed.products" path="/api/loyalty/feed/products" methods="GET">
        <default key="_controller">LoyaltyEngage\Controller\Api\ProductFeedController::feed</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>

    <!-- Admin API routes (bearer token auth) -->
    <route id="api.action.loyalty.cart.add" path="/api/v{version}/loyalty/shop/{email}/cart/add" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::addProductApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty.cart.remove" path="/api/v{version}/loyalty/shop/{email}/cart/remove" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::removeProductApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty.cart.remove.all" path="/api/v{version}/loyalty/shop/{email}/cart" methods="DELETE">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::removeAllProductsApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty.cart.claim.discount" path="/api/v{version}/loyalty/shop/{email}/cart/claim-discount" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\LoyaltyCartController::claimDiscountApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty_engage.customer.update" path="/api/_action/loyalty-engage/customer/update" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\CustomerLoyaltyController::updateCustomerLoyalty</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty_engage.customer.get" path="/api/_action/loyalty-engage/customer/get" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\CustomerLoyaltyController::getCustomerLoyalty</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>

    <!-- Points Redemption - Store API routes (frontend, customer session auth) -->
    <route id="store-api.loyalty.redeem-points" path="/store-api/loyalty/redeem-points" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::redeemPointsApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>
    
    <route id="store-api.loyalty.redeem-points.remove" path="/store-api/loyalty/redeem-points" methods="DELETE">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::removePointsDiscountApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>
    
    <route id="store-api.loyalty.redeem-points.info" path="/store-api/loyalty/redeem-points/info" methods="GET">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::getRedemptionInfoApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>
    
    <route id="store-api.loyalty.redeem-points.preview" path="/store-api/loyalty/redeem-points/preview" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::previewRedemptionApi</default>
        <default key="_routeScope">
            <list>
                <string>store-api</string>
            </list>
        </default>
        <default key="_loginRequired">true</default>
    </route>

    <!-- Points Redemption - Admin API routes (bearer token auth) -->
    <route id="api.action.loyalty.redeem-points" path="/api/v{version}/loyalty/shop/{email}/redeem-points" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::redeemPointsApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty.redeem-points.remove" path="/api/v{version}/loyalty/shop/{email}/redeem-points" methods="DELETE">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::removePointsDiscountApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty.redeem-points.info" path="/api/v{version}/loyalty/shop/{email}/redeem-points/info" methods="GET">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::getRedemptionInfoApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
    
    <route id="api.action.loyalty.redeem-points.preview" path="/api/v{version}/loyalty/shop/{email}/redeem-points/preview" methods="POST">
        <default key="_controller">LoyaltyEngage\Controller\Api\PointsRedemptionController::previewRedemptionApi</default>
        <default key="_routeScope">
            <list>
                <string>api</string>
            </list>
        </default>
    </route>
</routes>
